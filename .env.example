# Copy this file to .env and fill in real values. .env is gitignored — never commit it.

# Twilio (twilio.com console dashboard)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=+1XXXXXXXXXX
USER_PHONE_NUMBER=+91XXXXXXXXXX

# Deepgram (console.deepgram.com -> API Keys)
DEEPGRAM_API_KEY=

# Groq (console.groq.com -> API Keys) — free tier, no card required
GROQ_API_KEY=

# Public URL for this dev server, from `ngrok http 8000` (changes each time you restart ngrok
# unless you have a reserved domain) — must be the https/wss ngrok URL, no trailing slash
PUBLIC_BASE_URL=https://xxxxx.ngrok-free.app
